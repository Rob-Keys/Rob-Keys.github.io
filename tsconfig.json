{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "allowUmdGlobalAccess": true,
    "strictNullChecks": true,
    "noFallthroughCasesInSwitch": true,
    "lib": ["ES2020", "DOM"],
    "types": ["three"]
  },
  "include": ["js/**/*.js", "types/**/*.d.ts"],
  "exclude": ["node_modules", "js/vendor"]
}
